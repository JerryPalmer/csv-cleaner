{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run clean_csv",
      "type": "shell",
      "presentation": { "reveal": "always", "panel": "shared" },
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "& .\\.venv\\Scripts\\Activate.ps1; python .\\clean_csv.py \"${input:inputFile}\" \"${input:outputFile}\" --open-output"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "inputFile",
      "type": "promptString",
      "description": "Path to input CSV",
      "default": "${workspaceFolder}/sample.csv"
    },
    {
      "id": "outputFile",
      "type": "promptString",
      "description": "Path for cleaned CSV output",
      "default": "${workspaceFolder}/cleaned.csv"
    }
  ]
}
